main.tf:

    nano main.tf

data "aws_ami" "ubuntu" {
  most_recent = true
  owners      = ["099720109477"]

  filter {
    name   = "name"
    values = ["ubuntu/images/hvm-ssd-gp3/ubuntu-noble-24.04-amd64-server-*"]
  }

  filter {
    name   = "virtualization-type"
    values = ["hvm"]
  }
}

resource "aws_key_pair" "deployer" {
  key_name   = var.key_name
  public_key = file(var.public_key_path)

  tags = {
    Name = var.key_name
  }
}

module "network" {
  source = "./modules/network"

  project_name         = var.project_name
  environment          = var.environment
  vpc_cidr             = var.vpc_cidr
  public_subnet_1_cidr = var.public_subnet_1_cidr
  public_subnet_2_cidr = var.public_subnet_2_cidr
  availability_zone_1  = var.availability_zone_1
  availability_zone_2  = var.availability_zone_2
}

module "security" {
  source = "./modules/security"

  project_name   = var.project_name
  environment    = var.environment
  vpc_id         = module.network.vpc_id
  my_ip_cidr     = var.my_ip_cidr
  vpc_cidr_block = var.vpc_cidr
}

module "ec2" {
  source = "./modules/ec2"

  project_name             = var.project_name
  environment              = var.environment
  ami_id                   = data.aws_ami.ubuntu.id
  key_name                 = aws_key_pair.deployer.key_name
  instance_type_web        = var.instance_type_web
  instance_type_monitoring = var.instance_type_monitoring
  subnet_id_web            = module.network.public_subnet_1_id
  subnet_id_monitoring     = module.network.public_subnet_2_id
  web_sg_id                = module.security.web_sg_id
  monitoring_sg_id         = module.security.monitoring_sg_id
}

module "route53" {
  source = "./modules/route53"

  domain_name   = var.domain_name
  fqdn          = "${var.subdomain}.${var.domain_name}"
  web_public_ip = module.ec2.web_public_ip
}

resource "local_file" "ansible_inventory" {
  filename = "${path.module}/ansible/inventory.ini"

  content = templatefile("${path.module}/inventory.tpl", {
    web_public_ip         = module.ec2.web_public_ip
    monitoring_public_ip  = module.ec2.monitoring_public_ip
    web_private_ip        = module.ec2.web_private_ip
    monitoring_private_ip = module.ec2.monitoring_private_ip
    fqdn                  = "${var.subdomain}.${var.domain_name}"
    repo_url              = var.repo_url
    repo_branch           = var.repo_branch
    app_name              = var.app_name
  })
}

resource "local_file" "ansible_cfg" {
  filename = "${path.module}/ansible/ansible.cfg"
  content  = <<-EOT
[defaults]
inventory = inventory.ini
host_key_checking = False
remote_user = ubuntu
private_key_file = ${var.private_key_path}
retry_files_enabled = False
timeout = 30
interpreter_python = auto_silent
EOT
}

