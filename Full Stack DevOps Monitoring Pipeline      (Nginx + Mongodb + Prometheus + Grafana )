Nginx Role:

ansible/roles/nginx/tasks/

main.yml:

    Nano main.yml

---
- name: Update apt cache
  apt:
    update_cache: yes

- name: Install nginx and certbot
  apt:
    name:
      - nginx
      - certbot
      - python3-certbot-nginx
      - curl
    state: present

- name: Enable nginx
  systemd:
    name: nginx
    enabled: yes
    state: started

- name: Deploy nginx config
  template:
    src: nginx.conf.j2
    dest: /etc/nginx/sites-available/tech.dovin.xyz.conf
    mode: '0644'
  notify: Reload nginx

- name: Enable nginx site
  file:
    src: /etc/nginx/sites-available/tech.dovin.xyz.conf
    dest: /etc/nginx/sites-enabled/tech.dovin.xyz.conf
    state: link
  notify: Reload nginx

- name: Remove default nginx site
  file:
    path: /etc/nginx/sites-enabled/default
    state: absent
  notify: Reload nginx

- name: Ensure web root exists
  file:
    path: /var/www/tech.dovin.xyz/html
    state: directory
    recurse: yes

- name: Create sample index page
  copy:
    dest: /var/www/tech.dovin.xyz/html/index.html
    content: |
      <html>
      <head><title>tech.dovin.xyz</title></head>
      <body>
        <h1>tech.dovin.xyz is running</h1>
        <p>Nginx deployed by Ansible</p>
      </body>
      </html>
    mode: '0644'

- name: Test nginx config
  command: nginx -t
  register: nginx_test
  changed_when: false

- name: Reload nginx after config test
  systemd:
    name: nginx
    state: reloaded

# Run this only after DNS has pointed correctly
- name: Obtain Let's Encrypt certificate
  command: >
    certbot --nginx -d {{ domain_name }}
    --non-interactive
    --agree-tos
    -m admin@{{ domain_name | regex_replace('^.*?\\.', '') }}
    --redirect
  register: certbot_result
  failed_when: false
  changed_when: "'Congratulations' in certbot_result.stdout or 'Certificate not yet due for renewal' in certbot_result.stdout"


ansible/roles/nginx/templates/nginx.conf.j2:

    nano nginx.conf.j2

server {
    listen 80;
    server_name {{ domain_name }};

    root /var/www/tech.dovin.xyz/html;
    index index.html;

    location / {
        try_files $uri /index.html;
    }

    location /api/ {
        proxy_pass http://127.0.0.1:{{ app_port }}/;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /stub_status {
        stub_status;
        allow 127.0.0.1;
        allow {{ monitoring_private_ip }};
        deny all;
    }
}


