4.User_data.sh.tpl:

nano user_data.sh.tpl

#!/bin/bash
set -euxo pipefail

exec > >(tee /var/log/user-data.log | logger -t user-data -s 2>/dev/console) 2>&1

apt-get update -y
apt-get install -y git docker.io nginx curl

systemctl enable docker
systemctl start docker
systemctl enable nginx
systemctl start nginx

usermod -aG docker ubuntu || true

mkdir -p /opt/app
cd /opt/app

if [ ! -d app ]; then
  git clone -b ${repo_branch} ${repo_url} app
else
  cd app
  git fetch --all
  git reset --hard origin/${repo_branch}
  cd ..
fi

cd /opt/app/app/RMS-main

docker rm -f rehobath-marine-app || true

docker build -t rehobath-marine-app .

docker run -d \
  --name rehobath-marine-app \
  --restart unless-stopped \
  -p ${frontend_port}:${frontend_port} \
  -p ${backend_port}:${backend_port} \
  rehobath-marine-app

cat > /etc/nginx/sites-available/default <<EOF
server {
    listen 80 default_server;
    listen [::]:80 default_server;
    server_name _;

    location / {
        proxy_pass http://127.0.0.1:${frontend_port};
        proxy_http_version 1.1;
        proxy_set_header Host \$host;
        proxy_set_header X-Real-IP \$remote_addr;
        proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto \$scheme;
    }

    location /api/ {
        proxy_pass http://127.0.0.1:${backend_port}/;
        proxy_http_version 1.1;
        proxy_set_header Host \$host;
        proxy_set_header X-Real-IP \$remote_addr;
        proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto \$scheme;
    }
}
EOF

nginx -t
systemctl restart nginx
